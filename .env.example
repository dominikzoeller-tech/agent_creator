# AI Agent Builder System - Konfigurationsdatei
# Kopiere diese Datei zu .env und setze deine echten API-Keys

# OpenAI Konfiguration
OPENAI_API_KEY=your_api_key_here
OPENAI_MODEL=gpt-4
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2000

# Agent-Verhalten
MAX_REFINER_ITERATIONS=3
QUALITY_THRESHOLD=7.0

# Logging
LOG_LEVEL=INFO
