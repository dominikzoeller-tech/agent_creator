{
  "name": "agent_creator",
  "version": "1.0.0",
  "description": "Ein automatisiertes System zur Generierung und Optimierung von AI-Agenten mittels eines Multi-Varianten-Ansatzes. Das System erstellt automatisch 2-3 verschiedene Implementierungen für jede Anfrage, bewertet diese und wählt die beste Lösung aus.",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "council:test": "ts-node --project tsconfig.json test.ts",
    "master:test": "ts-node --project tsconfig.json master-test.ts",
    "json:test": "ts-node --project tsconfig.json json-test.ts",
    "agent:cli": "ts-node --project tsconfig.json cli.ts",
    "log:view": "ts-node --project tsconfig.json log-view.ts",
    "stats:view": "ts-node --project tsconfig.json decision-stats.ts",
    "health:check": "ts-node --project tsconfig.json health-check.ts",
    "routing:regression": "ts-node --project tsconfig.json routing-regression.ts",
    "env:check": "ts-node --project tsconfig.json validate-env.ts",
    "api:start": "ts-node --project tsconfig.json server.ts",
    "api:smoke": "ts-node --project tsconfig.json api-smoke-test.ts",
    "stack:up": "docker compose -f docker-compose.internal.yml up --build",
    "stack:up:detached": "docker compose -f docker-compose.internal.yml up --build -d",
    "stack:down": "docker compose -f docker-compose.internal.yml down",
    "stack:logs": "docker compose -f docker-compose.internal.yml logs -f",
    "stack:ps": "docker compose -f docker-compose.internal.yml ps",
    "stack:health": "powershell -ExecutionPolicy Bypass -File scripts/stack-health-check.ps1",
    "agent:capabilities:test": "npx ts-node agent-capabilities-smoke-test.ts",
    "agent:routing:test": "npx ts-node agent-routing-smoke-test.ts",
    "council:routing:metadata:test": "npx ts-node council-routing-metadata-smoke-test.ts",
    "phase6:preflight": "node scripts/phase6-4-preflight.cjs",
    "phase6:council:inspect": "node scripts/phase6-5-inspect-council-engine.cjs",
    "phase6:council:snippets": "node scripts/phase6-6-extract-council-engine-snippets.cjs",
    "phase6:council:patch": "node scripts/phase6-6-patch-council-engine.cjs",
    "phase6:council:metadata:fix": "node scripts/phase6-6b-fix-council-engine-metadata.cjs",
    "phase6:council:metadata:linefix": "node scripts/phase6-6c-line-fix-council-engine-metadata.cjs",
