    "knowledge:quality:verify": "node scripts/phase7-8-verify-knowledge-quality.cjs",
    "knowledge:quality:frontendfix": "node scripts/phase7-8b-fix-knowledge-quality-frontend-import.cjs",
    "knowledge:quality:frontendfix:verify": "node scripts/phase7-8b-verify-knowledge-quality-frontend-import.cjs",
    "knowledge:search:tune": "node scripts/phase7-9-patch-knowledge-search-tuning.cjs",
    "knowledge:search:smoke": "npx ts-node knowledge-search-tuning-smoke-test.ts",
